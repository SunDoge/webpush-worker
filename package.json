{
  "name": "webpush-worker",
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "pkgs/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && bun run dev",
    "dev:pwa": "cd apps/pwa && bun run dev",
    "dev": "bun run dev:api & bun run dev:pwa",
    "build": "bun --filter=@webpush-worker/pwa run build",
    "deploy": "bun run build && wrangler deploy --config apps/api/wrangler.jsonc",
    "gen-schema": "cd apps/api && bun run gen-schema",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write --unsafe ."
  },
  "resolutions": {
    "vite": "7.3.6",
    "sharp": "0.34.5",
    "sharp-ico": "^0.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2"
  }
}
